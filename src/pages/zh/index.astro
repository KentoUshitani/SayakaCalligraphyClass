---
import Header from '../../components/Header';
import Hero from '../../components/Hero';
import Philosophy from '../../components/Philosophy';
import Benefits from '../../components/Benefits';
import Credentials from '../../components/Credentials';
import Voices from '../../components/Voices';
import Services from '../../components/Services';
import AccessSchedule from '../../components/AccessSchedule';
import OnlineLesson from '../../components/OnlineLesson';
import Instructor from '../../components/Instructor';
import FAQ from '../../components/FAQ';
import FloatingLineCTA from '../../components/FloatingLineCTA';
import Footer from '../../components/Footer';
import '../../styles/global.css';

const lang = 'zh';
---

<!DOCTYPE html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <title>清枫书法教室 — 兵库县12教室・30年教学</title>
    <meta name="description" content="清枫书法教室在兵库县内运营12个教室。拥有30年教学经验的讲师，引导每位学员发现自身的闪光点。字写端正，心也端正。" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} client:load />
    <main>
      <Hero lang={lang} client:visible />
      <div id="philosophy">
        <Philosophy lang={lang} client:visible />
      </div>
      <div id="benefits">
        <Benefits lang={lang} client:visible />
      </div>
      <div id="credentials">
        <Credentials lang={lang} client:visible />
      </div>
      <div id="voices">
        <Voices lang={lang} client:visible />
      </div>
      <div id="classes">
        <Services lang={lang} client:visible />
      </div>
      <div id="access">
        <AccessSchedule lang={lang} client:visible />
      </div>
      <div id="online">
        <OnlineLesson lang={lang} client:visible />
      </div>
      <div id="instructor">
        <Instructor lang={lang} client:visible />
      </div>
      <div id="faq">
        <FAQ lang={lang} client:visible />
      </div>
    </main>
    <Footer lang={lang} client:visible />
    <FloatingLineCTA lang={lang} client:load />
  </body>
</html>
