---
import Header from '../../components/Header';
import Hero from '../../components/Hero';
import Philosophy from '../../components/Philosophy';
import Benefits from '../../components/Benefits';
import Credentials from '../../components/Credentials';
import Voices from '../../components/Voices';
import Services from '../../components/Services';
import AccessSchedule from '../../components/AccessSchedule';
import OnlineLesson from '../../components/OnlineLesson';
import Instructor from '../../components/Instructor';
import FAQ from '../../components/FAQ';
import FloatingLineCTA from '../../components/FloatingLineCTA';
import Footer from '../../components/Footer';
import '../../styles/global.css';

const lang = 'ko';
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <title>세이후 서예교실 — 효고현 12교실・30년 지도 경력</title>
    <meta name="description" content="세이후 서예교실은 효고현 내 12교실을 운영하고 있습니다. 30년 경력의 강사가 학생 한 사람 한 사람의 좋은 점을 끌어냅니다. 글씨가 바르면, 마음도 바르다." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;600;700;900&family=Noto+Sans+KR:wght@300;400;500;700&family=Noto+Serif+KR:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} client:load />
    <main>
      <Hero lang={lang} client:visible />
      <div id="philosophy">
        <Philosophy lang={lang} client:visible />
      </div>
      <div id="benefits">
        <Benefits lang={lang} client:visible />
      </div>
      <div id="credentials">
        <Credentials lang={lang} client:visible />
      </div>
      <div id="voices">
        <Voices lang={lang} client:visible />
      </div>
      <div id="classes">
        <Services lang={lang} client:visible />
      </div>
      <div id="access">
        <AccessSchedule lang={lang} client:visible />
      </div>
      <div id="online">
        <OnlineLesson lang={lang} client:visible />
      </div>
      <div id="instructor">
        <Instructor lang={lang} client:visible />
      </div>
      <div id="faq">
        <FAQ lang={lang} client:visible />
      </div>
    </main>
    <Footer lang={lang} client:visible />
    <FloatingLineCTA lang={lang} client:load />
  </body>
</html>
